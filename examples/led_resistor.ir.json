{
  "schemaVersion": "0.1",
  "name": "led_resistor_5v_10ma",
  "topology": "led_resistor",
  "description": "5 V source, E24 300 ohm current-limiting resistor, and a red LED model.",
  "nodes": ["vin", "led_anode", "0"],
