{
  "$defs": {
    "Analysis": {
      "additionalProperties": false,
      "description": "Structured simulation analysis.\n\nReplaces free-form `.tran`, `.op`, `.dc`, `.ac` strings with typed\nfields. Phase 2 will translate these into SPICE directives.",
      "properties": {
        "kind": {
          "$ref": "#/$defs/AnalysisKind"
        },
        "startTime": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "e.g. '0', '1m'. Required for tran.",
          "title": "Starttime"
        },
        "stopTime": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "e.g. '5m'. Required for tran.",
          "title": "Stoptime"
        },
        "stepTime": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Steptime"
        },
        "startFreq": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Startfreq"
        },
        "stopFreq": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stopfreq"
        },
        "pointsPerDecade": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pointsperdecade"
        },
        "sweepVariable": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sweepvariable"
        },
        "sweepStart": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sweepstart"
        },
        "sweepStop": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sweepstop"
        },
        "sweepStep": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sweepstep"
        }
      },
      "required": [
        "kind"
      ],
      "title": "Analysis",
      "type": "object"
    },
    "AnalysisKind": {
      "enum": [
        "op",
        "dc",
        "tran",
        "ac"
      ],
      "title": "AnalysisKind",
      "type": "string"
    },
    "Component": {
      "additionalProperties": false,
      "description": "One circuit element.\n\n`kind` is semantic (what it is). `spicePrefix` is the SPICE letter\n(V, I, R, C, L). Both must agree. This redundancy lets humans read\nthe IR while keeping a single source of truth for generation.",
      "properties": {
        "id": {
          "description": "Unique identifier, e.g. R1, C1, Vin",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ComponentKind"
        },
        "spicePrefix": {
          "description": "SPICE letter, must match kind",
          "title": "Spiceprefix",
          "type": "string"
        },
        "nodes": {
          "description": "Node terminals in canonical order for the kind",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Nodes",
          "type": "array"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "SPICE value string. Required for sources; for resistor / capacitor / inductor it is the value (e.g. '1k'). For diode / npn / pnp / nmos / pmos it is the SPICE model name (e.g. '1N4148', 'BC547', '2N7000'). For opamp it is the subcircuit name (e.g. 'UniversalOpamp').",
          "title": "Value"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional separate SPICE model name. When set on diode / npn / pnp / nmos / pmos, takes precedence over `value` for the model's model-name lookup. Kept separate so the value field on a resistor-style element still carries the physical value (e.g. '10k') without colliding with the model field on a semiconductor.",
          "title": "Model"
        },
        "role": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Semantic role used by planner and layout, e.g. series_resistor",
          "title": "Role"
        }
      },
      "required": [
        "id",
        "kind",
        "spicePrefix",
        "nodes"
      ],
      "title": "Component",
      "type": "object"
    },
    "ComponentKind": {
      "enum": [
        "voltage_source",
        "current_source",
        "resistor",
        "capacitor",
        "inductor",
        "diode",
        "npn",
        "pnp",
        "nmos",
        "pmos",
        "opamp"
      ],
      "title": "ComponentKind",
      "type": "string"
    },
    "Constraints": {
      "additionalProperties": true,
      "description": "Optional design targets (targetCutoffHz, targetGain, etc.).\n\nKeys are free-form (e.g. targetCutoffHz). Values must be flat scalars\n(str, int, float, bool). No nested dicts, no lists. This keeps the\ncontract reviewable and prevents accidental injection of complex\nobjects.",
      "properties": {},
      "title": "Constraints",
      "type": "object"
    },
    "Measurement": {
      "additionalProperties": false,
      "description": "A .meas expression to extract after simulation.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "analysis": {
          "$ref": "#/$defs/AnalysisKind"
        },
        "expression": {
          "minLength": 1,
          "title": "Expression",
          "type": "string"
        }
      },
      "required": [
        "name",
        "analysis",
        "expression"
      ],
      "title": "Measurement",
      "type": "object"
    },
    "Metadata": {
      "additionalProperties": true,
      "description": "Optional free-form metadata. Flat only, like Constraints.",
      "properties": {},
      "title": "Metadata",
      "type": "object"
    },
    "SemiconductorModel": {
      "additionalProperties": false,
      "description": "A SPICE ``.model`` block for a diode / BJT / MOSFET.\n\nThe model is emitted verbatim by the netlist generator (Phase 2)\nas ``.model <name> <type> (<params>)``. The ``name`` and ``type``\nare validated against the SPICE identifier pattern so they cannot\nsmuggle SPICE syntax through the IR.\n\nExamples::\n\n    SemiconductorModel(name=\"1N4148\", type=\"D\", params=(\"IS=2.55e-9\", \"RS=0.5\"))\n    SemiconductorModel(name=\"BC547\", type=\"NPN\", params=(\"BF=400\", \"VAF=80\"))",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "type": {
          "description": "SPICE model type, e.g. 'D', 'NPN', 'NMOS'",
          "minLength": 1,
          "title": "Type",
          "type": "string"
        },
        "params": {
          "description": "Raw SPICE model parameters",
          "items": {
            "type": "string"
          },
          "title": "Params",
          "type": "array"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "SemiconductorModel",
      "type": "object"
    },
    "Subcircuit": {
      "additionalProperties": false,
      "description": "A SPICE ``.subckt ... .ends`` definition for an opamp (or any X-prefixed call).\n\nThe netlist generator emits the block verbatim after all ``.model``\nblocks and before any component lines. The ``name`` becomes the\nfirst token of the ``.subckt`` line and the positional nodes are\nlisted before the inline ``params``. The optional ``body`` field\nis emitted verbatim inside the ``.subckt ... .ends`` block; the\ngenerator escapes nothing in it because the IR is internal.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "nodes": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Nodes",
          "type": "array"
        },
        "params": {
          "items": {
            "type": "string"
          },
          "title": "Params",
          "type": "array"
        },
        "body": {
          "items": {
            "type": "string"
          },
          "title": "Body",
          "type": "array"
        }
      },
      "required": [
        "name",
        "nodes"
      ],
      "title": "Subcircuit",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "LTspice AI Agent Circuit IR v0.1. Stable contract between AI intent and generated LTspice files. Validation rules in ir.py are the source of truth; this schema is a first-pass contract only.",
  "properties": {
    "schemaVersion": {
      "title": "Schemaversion",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "topology": {
      "title": "Topology",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "nodes": {
      "items": {
        "type": "string"
      },
      "title": "Nodes",
      "type": "array"
    },
    "components": {
      "items": {
        "$ref": "#/$defs/Component"
      },
      "minItems": 1,
      "title": "Components",
      "type": "array"
    },
    "analysis": {
      "items": {
        "$ref": "#/$defs/Analysis"
      },
      "minItems": 1,
      "title": "Analysis",
      "type": "array"
    },
    "measurements": {
      "items": {
        "$ref": "#/$defs/Measurement"
      },
      "title": "Measurements",
      "type": "array"
    },
    "probes": {
      "items": {
        "type": "string"
      },
      "title": "Probes",
      "type": "array"
    },
    "directives": {
      "items": {
        "type": "string"
      },
      "title": "Directives",
      "type": "array"
    },
    "constraints": {
      "anyOf": [
        {
          "$ref": "#/$defs/Constraints"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "models": {
      "items": {
        "$ref": "#/$defs/SemiconductorModel"
      },
      "title": "Models",
      "type": "array"
    },
    "subcircuits": {
      "items": {
        "$ref": "#/$defs/Subcircuit"
      },
      "title": "Subcircuits",
      "type": "array"
    },
    "metadata": {
      "anyOf": [
        {
          "$ref": "#/$defs/Metadata"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "schemaVersion",
    "name",
    "topology",
    "nodes",
    "components",
    "analysis"
  ],
  "title": "CircuitIR",
  "type": "object",
  "$id": "https://ltspice-ai-agent.local/schemas/circuit_ir.v0.1.schema.json"
}
